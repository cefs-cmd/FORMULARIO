<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cadastro de Clientes</title>
</head>
<body>
    <form>
 <!-- formulario dos nomes, etc.-->

    <h3>Formulario dos Dados Pessoais</h3>

    <label>Nome Completo:</label>
    <input type="text" required><br>
    <button type="reset">Limpar Formulário</button>

    <label>E-mail:</label>
    <input type="gmail" required><br>
    <button type="reset">Limpar Formulário</button>

    <label>Senha:</label>
    <input type="password" required><br>
    <button type="reset">Limpar Formulário</button>
    
    <label>Data de nascimento:</label>
    <input type="date" required><br>
    <button type="reset">Limpar Formulário</button>

    <label>CPF:</label>
    <input type="text"
           pattern="[0-9]{11}"
           placeholder="somente números"
           required>
    <button type="reset">Limpar Formulário</button>
     
    <label>Numero de Telefone:</label>
    <input type="text"
           pattern="[0-9]{11}"
           placeholder="somente números"
           required>
    <button type="reset">Limpar Formulário</button>

    <label>Nome da mãe:</label>
    <input type="text" required>
    <button type="reset">Limpar Formulário</button>

    <label>Nome do pai:</label>
    <input type="text" required>
    <button type="reset">Limpar Formulário</button>

    <label>Estado Civil:</label>
    <select required>
        <option value="">Selecione</option>
            <option>Solteiro</option>
            <option>Casado</option>
            <option>União Estável</option>
            <option>Separado</option>
    </select>
    <button type="reset">Limpar Formulário</button>

    


    <!--Endereço do Cliente-->

    <label>Rua:</label>
    <input type="text" required>
    <button type="reset">Limpar Formulário</button>

    <label>Numero:</label>
    <input type="text" required>
    <button type="reset">Limpar Formulário</button>

    <label>Bairro:</label>
    <input type="text" required>
    <button type="reset">Limpar Formulário</button>

    <label>Cidade:</label>
    <input type="text" required>
    <button type="reset">Limpar Formulário</button>

    <label>Estado:</label>
    <select required>
        <option value=""><selecione</option>
        <option>Pernambuco</option>
        <option>São Paulo</option>
        <option>Rio de Janeiro</option>
        <option>Bahia</option>
    </select>
    <button type="reset">Limpar Formulário</button>

    <label>Cep:</label>
    <input type="text"
         pattern="[0-9]{8}"
         placeholder="somente números"
         required>
    <button type="reset">Limpar Formulário</button>

    
    <label>Pais:</label>
    <select required>
        <option value=""><selecione</option>
        <option>Brasil</option>
        <option>Estados Unidos</option>
        <option>Canadá</option>
        <option>argentina</option>
    </select>
    <button type="reset">Limpar Formulário</button>

    <!--SEXO DO INDIVIDUO-->

    <div class="radio-group">
    <input type"radio" name="sexo" required>
    <label>Masculino</label>

    <input type="radio" name="sexo">
    <label>Feminino</label>
    </div>
    <button type="reset">Limpar Formulário</button>

    <!--TECNOLOGIAS-->

  <legend>Tecnologias</legend>

            <div class="checkbox-group">
                <input type="checkbox"> HTML <br>
                <input type="checkbox"> CSS <br>
                <input type="checkbox"> JavaScript <br>
                <input type="checkbox"> Python
            </div>


    <!--Comentarios-->

    <legend>Comentarios</legend>
    
    <label>Observações:</label>
    <textarea rows="5" required></textarea>
    <button type="reset">Limpar Formulário</button>

    <button type="submit">Enviar Cadastro</button>

</head>
